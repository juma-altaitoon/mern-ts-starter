# Node.js / Express .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
*.lcov

# Dependency directories
node_modules/
jspm_packages/

# Build output
dist/
build/
.tmp/

# Environment variables
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# IDE/editor settings
.vscode/
.idea/
*.swp

# Optional caches
.npm/
.yarn/
.pnp.*
.pnp.js

# Testing
/coverage
/.nyc_output

# Misc
*.tgz
*.tar.gz
